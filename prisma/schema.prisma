generator client {
  provider             = "prisma-client-py"
  recursive_type_depth = "-1"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model TranslationRequest {
  id                    String              @id @default(cuid())
  sourceLanguage        SourceLanguage
  targetLanguages       String[]
  languagePair          String
  wordCount             Int
  requestDate           DateTime            @default(now())
  requestTime           DateTime            @default(now())
  mtModel               MTModel             @default(MT5_BASE)
  modelName             String?
  fileName              String
  status                RequestStatus       @default(PENDING)
  requestType           RequestType         @default(SINGLE_ENGINE)
  selectedEngines       String[]
  totalProcessingTimeMs Int?
  createdAt             DateTime            @default(now())
  updatedAt             DateTime            @updatedAt
  qualityMetrics        QualityMetrics[] 
  
  // ===============================================
  // 🟢 FIX: RELATIONAL LINK TO SEGMENTATION SESSION
  // ===============================================
  segmentationSessionId String?             @unique // Ensure only one request per session
  segmentationSession   SegmentationSession? @relation(fields: [segmentationSessionId], references: [id])
  originalSegments      Json?
  advertiserProfileId   String?
  advertiserProfile     AdvertiserProfile?  @relation(fields: [advertiserProfileId], references: [id])
  translationStrings    TranslationString[]

  @@index([status]) // 💡 Performance index on frequently filtered column
  @@index([sourceLanguage])
  @@index([createdAt])
  @@map("translation_requests")
}
// ----------------------------------------------------------------------
model TranslationString {
  id                       String             @id @default(cuid())
  sourceText               String
  translatedText           String
  referenceText            String?
  referenceType            ReferenceType?
  targetLanguage           String
  status                   StringStatus       @default(DRAFT)
  isApproved               Boolean            @default(false)
  processingTimeMs         Int?
  lastModified             DateTime?
  engineResults            Json?
  selectedEngine           String?
  fuzzyMatches             Json               @default("[]")
  suggestedTranslation     String?
  tmMatchPercentage        Int?
  translationType          TranslationType    @default(STANDARD)
  intermediateTranslation  String?
  translationRequestId     String
  createdAt                DateTime           @default(now())
  updatedAt                DateTime           @updatedAt
  approvalType             ApprovalType?
  cognitiveLoad            Int?
  domainFamiliarity        Int?
  editDistance             Int?
  reviewerExpertise        ReviewerExpertise?
  annotatorId              HumanAnnotator     @default(REVIEWER_1)
  timeToReview             Int?
  selectedModelCombination String?
  selectedAt               DateTime?
  selectionMethod          String?
  originalTranslation      String?
  hasReference             Boolean?           @default(false)
  annotations              Annotation[]
  enginePreferences        EnginePreference[]
  modelOutputs             ModelOutput[]
  qualityMetrics           QualityMetrics[]
  llmJudgments             LLMJudgment[]
  personaTranscreations    PersonaTranscreation[]
  translationRequest       TranslationRequest @relation(fields: [translationRequestId], references: [id], onDelete: Cascade)

  @@index([status]) // 💡 Performance index on frequently filtered column
  @@index([targetLanguage])
  @@index([translationRequestId])
  @@index([createdAt])
  @@map("translation_strings")
}
// ----------------------------------------------------------------------
model QualityMetrics {
  id                   String              @id @default(cuid())
  metricXScore         Float?
  metricXConfidence    Float?
  metricXMode          EvaluationMode?
  metricXVariant       ModelVariant?
  bleuScore            Float?
  cometScore           Float?
  terScore             Float?
  chrfScore            Float?              
  qualityLabel         QualityLabel?
  hasReference         Boolean             @default(false)
  referenceType        ReferenceType?
  calculationEngine    String?
  engineName           String?  // MT engine that produced the hypothesis (null = single-engine / aggregated)

  translationRequestId String?

  translationStringId  String?
  createdAt            DateTime            @default(now())
  updatedAt            DateTime            @updatedAt

  translationRequest   TranslationRequest? @relation(fields: [translationRequestId], references: [id])
  translationString    TranslationString?  @relation(fields: [translationStringId], references: [id])

  @@index([translationRequestId])
  @@index([translationStringId])
  @@index([engineName])
  @@map("quality_metrics")
}
// ----------------------------------------------------------------------
model Annotation {
  id                  String             @id @default(cuid())
  category            AnnotationCategory
  severity            AnnotationSeverity
  comment             String
  reviewer            String?
  annotatorId         HumanAnnotator     @default(REVIEWER_1)
  textRange           Json?
  isResolved          Boolean            @default(false)
  resolution          String?
  translationStringId String
  createdAt           DateTime           @default(now())
  updatedAt           DateTime           @updatedAt
  confidenceInFix     Int?
  errorType           ErrorType? 
  sourceSpan          Json?
  suggestedFix        String?
  targetSpan          Json?
  translationString   TranslationString  @relation(fields: [translationStringId], references: [id], onDelete: Cascade)

  @@index([translationStringId])
  @@map("annotations")
}
// ----------------------------------------------------------------------
model TranslationMemory {
  id                String        @id @default(cuid())
  sourceText        String
  targetText        String
  sourceLanguage    String
  targetLanguage    String
  quality           MemoryQuality
  domain            String
  lastUsed          DateTime      @default(now())
  createdFrom       String?
  originalRequestId String?
  approvedBy        String?
  usageCount        Int           @default(0)
  personaId         String?       // null = profile-level TM; non-null = persona-scoped
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt

  @@index([sourceLanguage, targetLanguage])
  @@index([sourceText])
  @@map("translation_memory")
}
// ----------------------------------------------------------------------
model GlossaryTerm {
  id             String    @id @default(cuid())
  term           String
  translation    String
  sourceLanguage String
  targetLanguage String
  domain         String
  definition     String?
  notes          String?
  isActive       Boolean   @default(true)
  usageCount     Int       @default(0)
  lastUsed       DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  @@unique([term, sourceLanguage, targetLanguage])
  @@index([term])
  @@map("glossary_terms")
}
// ----------------------------------------------------------------------
model DoNotTranslateItem {
  id           String                 @id @default(cuid())
  text         String
  category     DoNotTranslateCategory
  languages    String[]
  notes        String?
  alternatives String?
  isActive     Boolean                @default(true)
  usageCount   Int                    @default(0)
  createdAt    DateTime               @default(now())
  updatedAt    DateTime               @updatedAt

  @@index([text])
  @@map("do_not_translate_items")
}
// ----------------------------------------------------------------------
model OffensiveWord {
  id             String            @id @default(cuid())
  word           String
  language       String
  severity       OffensiveSeverity
  category       OffensiveCategory
  alternatives   String[]
  isActive       Boolean           @default(true)
  detectionCount Int               @default(0)
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt

  @@unique([word, language])
  @@index([word])
  @@map("offensive_words")
}
// ----------------------------------------------------------------------
model SegmentationSession {
  id                String   @id @default(cuid())
  segmentationId    String   @unique
  originalFileName  String
  mediaType         MediaType
  segments          Json     // Array of segment objects with text, bbox, timestamps
  mediaData         String?  // Base64 encoded media for UI display
  detectedLanguage  String
  wordCount         Int
  sourceLanguage    String?  // User-selected after detection
  targetLanguages   String[] // Selected target languages
  useMultiEngine    Boolean  @default(false)
  selectedEngines   String[] // Selected engines for multi-engine mode
  status            SegmentationStatus @default(PROCESSING)
  createdAt         DateTime @default(now())
  expiresAt         DateTime // Auto-cleanup old sessions (e.g., +1 hour)
  updatedAt         DateTime @updatedAt

  // 🟢 FIX: REVERSE RELATION FROM TRANSLATION REQUEST
  translationRequest TranslationRequest? 

  @@map("segmentation_sessions")
}
// ----------------------------------------------------------------------
enum MediaType {
  IMAGE
  AUDIO  
  PDF
  TEXT
}

enum SegmentationStatus {
  PROCESSING
  READY_FOR_EDIT
  USER_EDITING
  COMPLETED
  EXPIRED
}
// ----------------------------------------------------------------------
model EnginePreference {
  id                  String            @id @default(cuid())
  selectedEngine      String
  rating              Int?
  comments            String?
  sourceLanguage      String
  targetLanguage      String
  textLength          Int?
  translationStringId String
  requestId           String?
  allEngineResults    Json?
  createdAt           DateTime          @default(now())
  overallSatisfaction Int?
  preferenceReason    PreferenceReason?
  preferenceStrength  Int?
  worstModel          String?
  worstModelReason    String?
  generationParams    Json?
  modelCombination    String?
  outputVariant       String?
  selectionMethod     String?
  translationString   TranslationString @relation(fields: [translationStringId], references: [id])

  @@index([selectedEngine])
  @@index([sourceLanguage, targetLanguage])
  @@map("engine_preferences")
}
// ----------------------------------------------------------------------
model ModelOutput {
  id                  String            @id @default(cuid())
  translationStringId String
  modelName           String
  engineName          String
  outputText          String
  confidence          Float?
  processingTimeMs    Int?
  generationParams    Json?
  isPivot             Boolean           @default(false)
  pivotIntermediate   String?
  createdAt           DateTime          @default(now())
  translationString   TranslationString @relation(fields: [translationStringId], references: [id])

  @@map("model_outputs")
}
// ----------------------------------------------------------------------
model LLMJudgment {
  id                  String            @id @default(cuid())
  translationStringId String
  engineName          String?
  judgeModel          String
  adequacyScore       Float
  fluencyScore        Float
  confidenceScore     Float
  rationale           String?
  cometDisagreement   Float?
  brandVoiceScore     Float?   // 0–5: how well output preserves advertiser brand voice
  culturalFitnessScore Float?  // 0–5: cultural appropriateness for target market
  wasRefined           Boolean  @default(false)  // true if agent refinement loop ran on this string
  refinementAttempts   Int?                       // number of refinement iterations performed
  agentIterations      Json?                      // [{attempt, feedback, brand_voice_before, brand_voice_after, text}]
  createdAt           DateTime          @default(now())
  updatedAt           DateTime          @updatedAt
  translationString   TranslationString @relation(fields: [translationStringId], references: [id], onDelete: Cascade)

  @@index([translationStringId])
  @@index([engineName])
  @@map("llm_judgments")
}
// ----------------------------------------------------------------------
model EvalSnapshot {
  id           String   @id @default(cuid())
  requestId    String?  // WMT benchmark TranslationRequest that was snapshotted
  languagePair String   // e.g. "jp-en"
  engineName   String?  // null = aggregated across all engines for this request
  runDate      DateTime @default(now())
  avgBleu      Float?
  avgComet     Float?
  avgChrf      Float?
  avgTer       Float?
  segmentCount Int
  notes        String?  // optional label, e.g. "baseline", "after OPUS-MT update"
  createdAt    DateTime @default(now())

  @@index([languagePair])
  @@index([engineName])
  @@index([runDate])
  @@map("eval_snapshots")
}
// ----------------------------------------------------------------------
model HumanFeedback {
  id                   String       @id @default(cuid())
  feedbackType         FeedbackType
  originalTranslation  String?
  humanEdit            String?
  revisionInstructions String?
  qualityScore         Float?
  translationA         String?
  translationB         String?
  preferred            String?
  sourceText           String
  sourceLanguage       String
  targetLanguage       String
  translationStringId  String?
  createdAt            DateTime     @default(now())

  @@index([feedbackType])
  @@map("human_feedback")
}
// ----------------------------------------------------------------------
model LocalModel {
  id                String    @id @default(cuid())
  modelName         String    @unique
  modelType         MTModel
  sourceLanguage    String
  targetLanguage    String
  isDownloaded      Boolean   @default(false)
  modelPath         String?
  modelSize         Int?
  avgProcessingTime Float?
  totalTranslations Int       @default(0)
  lastUsed          DateTime?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  engineType        String?

  @@map("local_models")
}
// ----------------------------------------------------------------------
model SystemConfig {
  id          String   @id @default(cuid())
  key         String   @unique
  value       String
  description String?
  updatedAt   DateTime @updatedAt

  @@map("system_config")
}
// ----------------------------------------------------------------------
model AdvertiserProfile {
  id            String            @id @default(cuid())
  brandName     String
  brandTone     BrandTone
  adRegister    AdRegister  @map("register")
  targetMarkets String[]          // e.g. ["JP", "FR"]
  keyTerms      String[]          // terms that MUST appear / be preserved
  tabooTerms    String[]          // terms to avoid in target copy
  policyNotes   String?           // free-text policy constraints
  isActive      Boolean           @default(true)
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt

  translationRequests TranslationRequest[]
  personas            Persona[]

  @@index([brandName])
  @@map("advertiser_profiles")
}
// ----------------------------------------------------------------------
model Persona {
  id                      String                 @id @default(cuid())
  name                    String                 // e.g. "Upgrader", "Switcher", "General"
  psychographicDescription String                // who this person is and what motivates them
  messagingPriorities     String[]               // e.g. ["emphasize ROI", "address switching cost"]
  toneOverride            BrandTone?             // optional: overrides AdvertiserProfile.brandTone
  registerOverride        AdRegister?            // optional: overrides AdvertiserProfile.adRegister
  advertiserProfileId     String
  advertiserProfile       AdvertiserProfile      @relation(fields: [advertiserProfileId], references: [id], onDelete: Cascade)
  personaTranscreations   PersonaTranscreation[]
  createdAt               DateTime               @default(now())
  updatedAt               DateTime               @updatedAt

  @@index([advertiserProfileId])
  @@map("personas")
}
// ----------------------------------------------------------------------
model PersonaTranscreation {
  id                   String                    @id @default(cuid())
  translationStringId  String
  translationString    TranslationString         @relation(fields: [translationStringId], references: [id], onDelete: Cascade)
  personaId            String
  persona              Persona                   @relation(fields: [personaId], references: [id], onDelete: Cascade)
  targetLanguage       String
  outputText           String?                   // null until first attempt completes
  status               PersonaTranscreationStatus @default(PENDING)
  brandVoiceScore      Float?                    // 0-5
  culturalFitnessScore Float?                    // 0-5
  tabooViolation       Boolean?
  keyTermMissing       Boolean?
  differentiationScore Float?                    // avg pairwise cosine similarity vs other personas (lower = more distinct)
  refinementAttempts   Int                       @default(0)
  agentIterations      Json?                     // [{attempt, feedback, brand_voice_before, brand_voice_after, cultural_fitness_after, text}]
  rationale            String?
  createdAt            DateTime                  @default(now())
  updatedAt            DateTime                  @updatedAt

  @@index([translationStringId])
  @@index([personaId])
  @@map("persona_transcreations")
}
// ----------------------------------------------------------------------
enum RequestType {
  SINGLE_ENGINE
  MULTI_ENGINE
  WMT_BENCHMARK
  PIVOT_TRANSLATION
  PERSONA_TRANSCREATION
}

enum PersonaTranscreationStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  NEEDS_REVIEW
  FAILED
}

enum SourceLanguage {
  EN
  JP
  FR
  SW
}

enum MTModel {
  MARIAN_MT_EN_FR
  MARIAN_MT_FR_EN
  MARIAN_MT_EN_JP
  ELAN_MT_JP_EN
  T5_MULTILINGUAL
  CUSTOM_MODEL
  MULTI_ENGINE
  PIVOT_JP_EN_FR
  MT5_BASE
  PLAMO_2_TRANSLATE
  OPUS_MT_JA_EN
  OPUS_MT_EN_JAP
  OPUS_MT_TC_BIG_EN_FR
  NLLB_MULTILINGUAL
  PIVOT_ELAN_HELSINKI
  MT5_MULTILINGUAL
  GEMINI_TRANSCREATION
}

enum RequestStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  CANCELLED
  MULTI_ENGINE_REVIEW
}

enum ReferenceType {
  WMT
  HUMAN_APPROVED
  PROFESSIONAL
  AUTO_GENERATED
  HUMAN_REFERENCE
  MACHINE_REFERENCE
  FUZZY_MATCH
  TRANSLATION_MEMORY
  POST_EDITED
  BACK_TRANSLATION
  SYNTHETIC
}

enum TranslationType {
  STANDARD
  PIVOT
  WMT_BENCHMARK
  MULTI_ENGINE
}

enum StringStatus {
  DRAFT
  REVIEWED
  FINALIZED
  MULTI_ENGINE_REVIEW
  APPROVED
}

enum EvaluationMode {
  REFERENCE_BASED
  REFERENCE_FREE
  HYBRID
}

enum ModelVariant {
  METRICX_24_HYBRID
  METRICX_24_XL
  METRICX_24_XXL
  METRICX_24_REF
  METRICX_24_SRC
  CUSTOM
}

enum QualityLabel {
  EXCELLENT
  GOOD
  FAIR
  POOR
  ERROR
  CRITICAL
}

enum AnnotationCategory {
  ACCURACY
  FLUENCY
  TERMINOLOGY
  GRAMMAR
  WORD_CHOICE
  CONTEXT
  STYLE
  LOCALE_CONVENTION
  OTHER
  // Advertising-specific categories
  BRAND_VOICE_DEVIATION   // output doesn't match registered brand tone
  CULTURAL_MISSTEP        // culturally inappropriate for target market
  POLICY_FLAG             // potential compliance / Amazon Ads policy issue
  MISSED_TRANSCREATION    // literal when cultural adaptation was needed
  REGISTER_MISMATCH       // wrong formality level for audience
}

enum ApprovalType {
  IMMEDIATE
  MINOR_EDIT
  MAJOR_EDIT
  COMPLETE_REWRITE
}

enum ReviewerExpertise {
  NATIVE
  PROFESSIONAL
  BILINGUAL
  LEARNER
}

enum HumanAnnotator {
  REVIEWER_1
  REVIEWER_2
  REVIEWER_3
}

enum ErrorType {
  OMISSION
  ADDITION
  MISTRANSLATION
  WORD_ORDER
  REGISTER
  AMBIGUITY
  CULTURAL_CONTEXT
  PUNCTUATION 
  SPELLING 
}

enum PreferenceReason {
  ACCURACY
  FLUENCY
  STYLE
  TERMINOLOGY
  CULTURAL_FIT
  NATURALNESS
}

enum AnnotationSeverity {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum MemoryQuality {
  HIGH
  MEDIUM
  LOW
}

enum DoNotTranslateCategory {
  PROPER_NOUN
  BRAND
  TECHNICAL
  ACRONYM
  OTHER
}

enum OffensiveSeverity {
  LOW
  MEDIUM
  HIGH
}

enum OffensiveCategory {
  PROFANITY
  HATE_SPEECH
  DISCRIMINATORY
  INAPPROPRIATE
  OTHER
}

enum FeedbackType {
  TRANSLATION_EDIT
  QUALITY_RATING
  PREFERENCE_COMPARISON
  ANNOTATION
}

enum BrandTone {
  AUTHORITATIVE
  PLAYFUL
  LUXURY
  APPROACHABLE
  TECHNICAL
  BOLD
}

enum AdRegister {
  FORMAL
  INFORMAL
  NEUTRAL
}